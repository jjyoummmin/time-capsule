# Neon: Dashboard → Connection string → copy "URI"
# (ssl 경고 줄이려면 sslmode=verify-full 권장)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full

# Optional
# PORT=8787
# Render/PaaS 기본은 0.0.0.0 — 로컬만 127.0.0.1 쓰려면: HOST=127.0.0.1
# HOST=0.0.0.0
# PG_POOL_MAX=10
# Local Postgres without TLS: PGSSLMODE=disable
# 정적 파일 경로가 다르면: WEB_DIST=/absolute/path/to/web/dist
